{
    "name": "adedaramola/termii-notification-channel",
    "description": "Termii Notification Channel for Laravel",
    "homepage": "https://github.com/oxiginedev/termii-notification-channel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Adedaramola Adetimehin",
            "email": "adedaramolaadetimehin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/notifications": "^12.54",
        "illuminate/support": "^12.54"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.9",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Adedaramola\\TermiiNotificationChannel\\": "src/"
        }
    },
    "scripts": {
        "lint": [
            "rector",
            "pint --parallel"
        ],
        "lint:check": [
            "rector --dry-run",
            "pint --parallel --test"
        ],
        "test:types": [
            "phpstan"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}